DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_multitenant?schema=public"

# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Seed — usuário de teste criado pelo pnpm db:seed
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""

# Cloudflare Turnstile (anti-bot) — https://dash.cloudflare.com/
# Sem esta variável, o widget não é renderizado (graceful degradation)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
