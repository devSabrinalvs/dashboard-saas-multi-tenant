# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Dashboard SaaS Multi-tenant
#
# Copie este arquivo para .env.local (desenvolvimento) ou configure no painel
# do seu provedor de cloud (Vercel, Railway, etc.) para produção.
# NUNCA commite valores reais neste arquivo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
# Desenvolvimento local (Docker):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_multitenant?schema=public"
# Produção (Neon, Supabase, Railway):
#   Use a connection string fornecida pelo provedor.
#   Para Neon, use a connection string com pooler (porta 5432 → pooled).
DATABASE_URL=""

# ── Autenticação (NextAuth v4) ────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# URL pública da aplicação (sem barra no final)
# Dev:  http://localhost:3000
# Prod: https://seu-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# NECESSÁRIO em produção quando há proxy reverso (Vercel, Railway, Nginx)
# Garante que NextAuth confie no host do proxy
AUTH_TRUST_HOST=true

# ── Segurança de senhas ───────────────────────────────────────────────────────
# Pepper concatenado à senha antes do bcrypt (cost 12)
# Gere com: openssl rand -base64 32
# ⚠️  ATENÇÃO: alterar este valor invalida TODAS as senhas existentes
PASSWORD_PEPPER=""

# ── Encriptação 2FA (TOTP) ────────────────────────────────────────────────────
# Chave AES-256-GCM para encriptar segredos TOTP no banco
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ⚠️  ATENÇÃO: alterar este valor invalida todos os 2FA configurados
TWO_FACTOR_ENCRYPTION_KEY=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys → Create API Key
# Sem RESEND_API_KEY, links de email aparecem no console (dev fallback)
RESEND_API_KEY=""

# Remetente verificado no Resend — deve usar domínio verificado em produção
# Formato: "Nome Exibido <email@seudominio.com>"
RESEND_FROM="Projorg <no-reply@seudominio.com>"

# ── URLs e deep links ─────────────────────────────────────────────────────────
# Usada para montar links de email (reset de senha, verificação, etc.)
# Dev:  http://localhost:3000
# Prod: https://seu-app.vercel.app
APP_BASE_URL="http://localhost:3000"

# ── Cloudflare Turnstile (anti-bot) ──────────────────────────────────────────
# https://dash.cloudflare.com/ → Turnstile → Add Site
# Sem estas variáveis, o widget não é renderizado e a validação server é pulada
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Observabilidade (opcional) ────────────────────────────────────────────────
# Sentry DSN — se ausente, Sentry é desabilitado (graceful degradation)
# Requer: pnpm add @sentry/nextjs
# https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=""

# Nível de log: debug | info | warn | error  (padrão: info)
LOG_LEVEL="info"

# Versão da aplicação — exibida em /api/health e logs
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
# Use chaves de teste (sk_test_...) em dev/staging, live (sk_live_...) em prod
STRIPE_SECRET_KEY=""

# Segredo do webhook — gerado ao criar o endpoint no Dashboard ou via CLI:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=""

# Price IDs dos planos (Dashboard → Products → seu produto → Pricing)
# Use Price IDs de teste (price_test_...) em dev
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_BUSINESS=""

# Segredo do cron job de billing — deve coincidir com o secret configurado no GitHub Actions
# Gere com: openssl rand -base64 32
# Se ausente, o endpoint aceita qualquer request (apenas para dev local)
CRON_SECRET=""

# ── Admin Console interno ─────────────────────────────────────────────────────
# Lista de emails autorizados a acessar /admin (separados por vírgula)
# ⚠️  ATENÇÃO: qualquer email aqui tem acesso total ao Admin Console
# Recomendação forte: habilitar 2FA para todos os admins listados
ADMIN_ALLOWLIST=""

# Se "true", exige que o usuário tenha 2FA ativo para acessar o Admin Console
ADMIN_REQUIRE_2FA="false"

# ── Seed (apenas desenvolvimento) ────────────────────────────────────────────
# Usuários criados pelo pnpm db:seed
SEED_USER_EMAIL=""
SEED_USER_PASSWORD=""
