generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

/// Plano de assinatura da organização.
/// FREE: limites básicos. PRO: uso profissional. BUSINESS: escala corporativa.
enum Plan {
  FREE
  PRO
  BUSINESS
}

/// Status da assinatura Stripe.
/// PAST_DUE: mantém plano ativo com banner de aviso (grace period).
/// CANCELED: downgrade para FREE.
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

enum MilestoneStatus {
  OPEN
  CLOSED
}

// ─── Auth.js required models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// Senha com hash bcrypt. Null para usuários OAuth (futuro).
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Two-factor authentication ──────────────────────────────────────────────
  /// Se o usuário tem 2FA ativado.
  twoFactorEnabled             Boolean   @default(false)
  /// Secret TOTP criptografado com AES-256-GCM. Null quando 2FA desativado.
  totpSecretEncrypted          String?
  /// Secret TOTP temporário durante o wizard de setup (antes de confirmar).
  twoFactorTempSecretEncrypted String?
  /// Timestamp de quando o 2FA foi ativado.
  twoFactorEnabledAt           DateTime?
  /// Hashes SHA-256 dos recovery codes. Array vazio quando não configurado.
  twoFactorRecoveryCodeHashes  String[]

  twoFactorVerifications TwoFactorVerification[]
  trustedDevices         TrustedDevice[]

  // ── Soft delete ────────────────────────────────────────────────────────────
  /// Timestamp de deleção suave. Non-null = conta excluída; login bloqueado.
  deletedAt DateTime?

  // ── Login lockout ──────────────────────────────────────────────────────────
  /// Número de tentativas de login com falha desde o último login bem-sucedido.
  failedLoginCount    Int       @default(0)
  /// Se preenchido e no futuro, a conta está bloqueada até este momento.
  lockedUntil         DateTime?
  /// Timestamp da última tentativa de login com falha.
  lastFailedLoginAt   DateTime?
  /// Timestamp do último login bem-sucedido.
  lastLoginAt         DateTime?
  /// Timestamp do último email de alerta de segurança enviado (cooldown de 6h).
  lastSecurityAlertAt DateTime?

  accounts                Account[]
  sessions                Session[]
  sessionMetas            UserSessionMeta[]
  memberships             Membership[]
  /// Logs de auditoria onde este usuário foi o ator.
  /// Quando o usuário é deletado, actorUserId vira NULL (onDelete: SetNull).
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  /// Tarefas atribuídas a este usuário.
  assignedTasks           Task[]                   @relation("TaskAssignee")
  /// Comentários feitos pelo usuário em tasks.
  taskComments            TaskComment[]             @relation("TaskComments")
  /// Notificações recebidas pelo usuário.
  notifications           Notification[]            @relation("UserNotifications")
  /// Histórico de atividade em tasks (ator).
  taskActivities          TaskActivity[]            @relation("TaskActivityActor")
  /// Registros de tempo.
  timeEntries             TimeEntry[]               @relation("UserTimeEntries")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// Usada apenas com strategy: "database". Com JWT, não é populada.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-tenant models ──────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  /// Identificador único legível por humanos (ex: "minha-empresa").
  slug      String   @unique
  /// Plano ativo. Alterado APENAS via webhook Stripe (fonte da verdade).
  plan      Plan     @default(FREE)
  /// Timestamp da última alteração de plano.
  planUpdatedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Stripe Billing ─────────────────────────────────────────────────────────
  /// ID do Customer no Stripe. Criado no primeiro checkout.
  stripeCustomerId     String?            @unique
  /// ID da assinatura ativa no Stripe.
  stripeSubscriptionId String?            @unique
  /// ID do Price (produto) da assinatura atual — usado para mapear ao Plan.
  stripePriceId        String?
  /// Status atual da assinatura Stripe.
  subscriptionStatus   SubscriptionStatus?
  /// Fim do período atual da assinatura (Unix timestamp convertido para DateTime).
  currentPeriodEnd     DateTime?
  /// Email de billing registrado no Customer Stripe.
  billingEmail         String?
  /// Até quando o plano pago é mantido em caso de falha de pagamento (grace period).
  /// Nulo = sem grace ativo.
  graceUntil           DateTime?
  /// Se true, a assinatura será cancelada ao fim do período atual.
  cancelAtPeriodEnd    Boolean   @default(false)

  memberships    Membership[]
  billingEmails  BillingEmailSent[]
  invites        Invite[]
  auditLogs      AuditLog[]
  projects       Project[]
  tasks          Task[]
  tags           OrgTag[]
  milestones     Milestone[]
  webhooks       OrgWebhook[]
  templates      ProjectTemplate[]
  apiKeys        ApiKey[]
  customFieldDefs CustomFieldDef[]
}

/// Vínculo entre User e Organization com papel (role).
model Membership {
  id        String   @id @default(cuid())
  role      Role     @default(MEMBER)
  userId    String
  orgId     String
  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

/// Convite por email para entrar em uma organização.
model Invite {
  id         String       @id @default(cuid())
  orgId      String
  email      String
  /// Token único enviado no link do convite.
  token      String       @unique
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  acceptedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)

  @@index([orgId, email])
}

/// Registro imutável de ações realizadas dentro de uma organização.
model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  /// Null quando o usuário ator foi deletado.
  actorUserId String?
  /// Ex: "project.created", "member.invited", "task.status_changed".
  action      String
  /// Dados adicionais da ação em formato livre.
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  actor        User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model Project {
  id          String   @id @default(cuid())
  orgId       String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  tasks        Task[]
  milestones   Milestone[]

  @@index([orgId])
}

model Task {
  id          String     @id @default(cuid())
  orgId       String
  projectId   String
  title       String
  description String?
  status      TaskStatus @default(TODO)
  /// Prioridade da tarefa. Padrão: MEDIUM.
  priority    Priority   @default(MEDIUM)
  /// Data de vencimento. Null = sem prazo.
  dueDate     DateTime?
  /// Tags livres para filtragem (ex: ["bug", "urgente"]).
  tags        String[]
  /// Responsável pela tarefa. Null = sem responsável. Deve ser membro da org.
  assigneeUserId String?
  /// Task pai. Null = tarefa raiz. Non-null = sub-tarefa.
  parentTaskId String?
  /// Milestone / Sprint ao qual esta tarefa pertence.
  milestoneId  String?
  /// Recorrência: null = não recorrente.
  recurrence   String?
  /// Próxima ocorrência programada (usado pelo cron).
  nextOccurrenceAt DateTime?
  /// ID da task-modelo original para instâncias recorrentes.
  recurringParentId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  /// Usuário responsável. Null quando o responsável é removido da org ou do sistema.
  assignee     User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  /// Task pai (sub-tarefa). Null quando a task pai é deletada (SetNull).
  parent       Task?        @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  /// Sub-tarefas desta task.
  subTasks     Task[]       @relation("SubTasks")
  /// Comentários desta task.
  comments     TaskComment[]
  /// Histórico de atividade desta task.
  activities   TaskActivity[]
  /// Registros de tempo desta task.
  timeEntries  TimeEntry[]
  /// Milestone ao qual esta task pertence.
  milestone    Milestone?   @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  /// Tarefas que esta task bloqueia (ela é pré-requisito).
  blocks       TaskDependency[] @relation("BlockingTask")
  /// Tarefas que bloqueiam esta task (pré-requisitos).
  blockedBy    TaskDependency[] @relation("BlockedTask")
  /// Valores de campos customizados.
  customValues CustomFieldValue[]

  @@index([orgId, projectId, status])
  @@index([orgId, assigneeUserId])
  @@index([parentTaskId])
  @@index([milestoneId])
}

/// Comentário em uma tarefa. Append-friendly — edição só pelo autor.
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  orgId     String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskComments", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([orgId])
}

/// Notificação in-app para um usuário.
/// Tipos: "task.assigned" | "task.commented" | "task.due_soon"
model Notification {
  id        String    @id @default(cuid())
  userId    String
  orgId     String
  /// Tipo da notificação
  type      String
  /// Mensagem legível
  message   String
  /// Link para a entidade relacionada (ex: /org/slug/projects/id)
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([orgId])
}

/// Token de verificação de email (gerado no signup / reenvio).
/// Armazena apenas o hash SHA-256 do token raw — nunca o token em texto claro.
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  /// SHA-256 do token raw enviado por email. Unique para evitar colisões.
  tokenHash String    @unique
  expiresAt DateTime
  /// Preenchido quando o token é consumido (verificação ou invalidação).
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Token de redefinição de senha (gerado em forgot-password).
/// Armazena apenas o hash SHA-256 do token raw — nunca o token em texto claro.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  /// SHA-256 do token raw enviado por email. Unique para evitar colisões.
  tokenHash String    @unique
  expiresAt DateTime
  /// Preenchido quando o token é consumido (reset ou invalidação).
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

/// Verificação 2FA pendente — criada após TOTP validado; consumida pelo JWT callback.
/// Permite que o servidor sinalize ao JWT que o segundo fator foi completado.
model TwoFactorVerification {
  id        String   @id @default(cuid())
  userId    String
  /// Nonce da sessão JWT para correlacionar com o token correto.
  nonce     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nonce])
}

/// Dispositivo de confiança: pula 2FA por 30 dias após "Remember this device".
model TrustedDevice {
  id         String    @id @default(cuid())
  userId     String
  /// SHA-256 do token raw armazenado no cookie HttpOnly.
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Metadata de sessão de login (compatível com JWT strategy do NextAuth).
/// sessionId é um ID opaco armazenado no JWT — nunca expõe o token raw.
/// Permite listar, identificar e revogar sessões individuais.
model UserSessionMeta {
  id          String    @id @default(cuid())
  userId      String
  /// ID opaco gerado no login e armazenado no JWT. Nunca é o token raw.
  sessionId   String    @unique
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  ip          String?
  userAgent   String?
  /// Label legível gerado a partir do userAgent (ex: "Chrome em macOS").
  deviceLabel String?
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

/// Bucket de rate limiting com janela fixa (fixed window).
/// key = identificador único por rota + ator (ex: "rl:invite:orgId:userId").
model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

/// Registro do último email de billing enviado por org+tipo.
/// Permite impor cooldown de 24h para não spammar owners em caso de falha recorrente.
model BillingEmailSent {
  id     String   @id @default(cuid())
  orgId  String
  /// Tipo do email: "payment_failed" | "subscription_canceled" | "downgraded"
  type   String
  sentAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, type])
}

/// Registro de eventos Stripe já processados — garante idempotência.
/// stripeEventId é o ID único do evento enviado pelo Stripe.
/// Antes de processar um webhook, verificar se o ID já existe aqui.
model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  processedAt   DateTime @default(now())
}

/// Histórico de atividade de uma tarefa (status, prioridade, assignee, título, etc.).
/// Append-only — nunca deletar registros.
model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  orgId     String
  /// Null quando o usuário ator foi deletado.
  userId    String?
  /// Ex: "status.changed", "priority.changed", "assignee.changed", "title.changed", "created"
  action    String
  /// Dados da mudança (ex: { from: "TODO", to: "IN_PROGRESS" })
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation("TaskActivityActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([orgId])
}

/// Tag com cor definida por organização.
/// Tasks referenciam tags pelo nome (String[]); OrgTag define a paleta visual.
model OrgTag {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  /// Cor hex (ex: "#6366f1"). Padrão: índigo.
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
}

/// Milestone (sprint) dentro de um projeto.
model Milestone {
  id          String          @id @default(cuid())
  orgId       String
  projectId   String
  name        String
  description String?
  startDate   DateTime?
  dueDate     DateTime?
  status      MilestoneStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Restrict)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  tasks        Task[]

  @@index([orgId, projectId])
}

/// Registro de tempo trabalhado em uma tarefa.
model TimeEntry {
  id              String    @id @default(cuid())
  taskId          String
  orgId           String
  userId          String
  startedAt       DateTime
  stoppedAt       DateTime?
  /// Duração calculada em minutos. Null enquanto o timer está rodando.
  durationMinutes Int?
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("UserTimeEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([orgId, userId])
}

/// Webhook configurado por organização para receber eventos.
model OrgWebhook {
  id        String   @id @default(cuid())
  orgId     String
  /// URL de destino do webhook.
  url       String
  /// Lista de eventos assinados (ex: ["task.created", "task.status_changed"]).
  events    String[]
  /// Secret HMAC-SHA256 para assinatura do payload.
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@index([orgId])
}

/// Registro de entrega de webhook (para debug e reenvio).
model WebhookDelivery {
  id          String    @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  error       String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  webhook OrgWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
}

/// Template de projeto com tarefas pré-definidas.
/// orgId null = template de sistema (disponível para todas as orgs).
model ProjectTemplate {
  id          String   @id @default(cuid())
  orgId       String?
  name        String
  description String?
  /// Array JSON de tasks: [{ title, status, priority, tags }]
  tasksJson   Json     @default("[]")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

/// Dependência entre tarefas: blockingTaskId é pré-requisito de blockedTaskId.
model TaskDependency {
  id            String   @id @default(cuid())
  orgId         String
  /// Task que bloqueia (pré-requisito).
  blockingTaskId String
  /// Task bloqueada (depende da outra).
  blockedTaskId  String
  createdAt     DateTime @default(now())

  blockingTask Task @relation("BlockingTask", fields: [blockingTaskId], references: [id], onDelete: Cascade)
  blockedTask  Task @relation("BlockedTask",  fields: [blockedTaskId],  references: [id], onDelete: Cascade)

  @@unique([blockingTaskId, blockedTaskId])
  @@index([orgId])
  @@index([blockedTaskId])
}

/// Chave de API por organização para integrações externas.
model ApiKey {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  /// SHA-256 do token raw — nunca armazenar o token em texto claro.
  keyHash     String    @unique
  /// Prefixo legível (primeiros 8 chars do token raw).
  prefix      String
  createdById String
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

/// Definição de campo customizado por organização.
model CustomFieldDef {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  /// TEXT | NUMBER | DATE | SELECT
  type      String
  /// Opções disponíveis para type=SELECT.
  options   String[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  values       CustomFieldValue[]

  @@unique([orgId, name])
  @@index([orgId])
}

/// Valor de um campo customizado para uma task específica.
model CustomFieldValue {
  id         String   @id @default(cuid())
  fieldDefId String
  taskId     String
  orgId      String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fieldDef CustomFieldDef @relation(fields: [fieldDefId], references: [id], onDelete: Cascade)
  task     Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([fieldDefId, taskId])
  @@index([taskId])
  @@index([orgId])
}

/// Log de auditoria do Admin Console interno.
/// Append-only — nunca deletar registros.
/// actorAdminUserId: email do admin (não FK — admin pode ser removido da allowlist).
model AdminAuditLog {
  id               String   @id @default(cuid())
  /// Email do administrador que realizou a ação.
  actorAdminEmail  String
  /// Ex: "admin.user.unlock", "admin.org.force_plan"
  action           String
  /// "user" | "org"
  targetType       String
  /// userId ou orgId alvo.
  targetId         String
  /// Dados adicionais da ação (ex: plano anterior/novo, email do usuário).
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())

  @@index([actorAdminEmail])
  @@index([targetType, targetId])
  @@index([action])
}
